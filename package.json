{
  "name": "jwt-up",
  "version": "1.0.0",
  "description": "jwt server",
  "author": "Alex Furmanov",
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/alx77/jwt-up.git"
  },
  "scripts": {
    "build": "tsc && find src -name 'function.json' | while read f; do dest=\"dist/${f}\"; mkdir -p \"$(dirname $dest)\"; cp \"$f\" \"$dest\"; done",
    "start": "node dist/index.js",
    "start:dev": "tsx index.ts",
    "watch": "tsx watch index.ts",
    "test": "vitest run --reporter=verbose test/unit",
    "test:it": "INTEGRATION_TEST=true vitest run test/integration",
    "test:i": "dev/test-runner.sh start; INTEGRATION_TEST=true vitest run test/integration; EXIT_CODE=$?; dev/test-runner.sh stop; exit $EXIT_CODE",
    "test:coverage": "vitest run --coverage",
    "startenv": "dev/test-runner.sh start",
    "stopenv": "dev/test-runner.sh stop"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "axios": "^1.8.4",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "express-prom-bundle": "^8.0.0",
    "fs": "latest",
    "http": "latest",
    "iconv-lite": "^0.6.3",
    "ioredis": "^5.7.0",
    "joi": "^17.1.1",
    "joi-to-swagger": "^6.2.0",
    "jsonfile": "^6.1.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "kafkajs-snappy": "^1.1.0",
    "knex": "^3.1.0",
    "luxon": "^3.7.2",
    "mime": "^4.0.7",
    "nconf": "^0.12.1",
    "nodemailer": "^7.0.10",
    "path": "latest",
    "pg": "^8.14.1",
    "redis": "^5.8.2",
    "supertest": "^7.1.0",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.8.3",
    "url": "latest",
    "uuid": "latest",
    "winston": "^3.17.0",
    "zod": "^4.3.2",
    "zod-openapi": "^5.4.5"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/body-parser": "^1.19.5",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/nconf": "^0.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "child_process": "^1.0.2",
    "rewire": "7.0.0",
    "tsx": "^4.19.3",
    "vitest": "^4.0.15",
    "wait-on": "^9.0.3"
  }
}
